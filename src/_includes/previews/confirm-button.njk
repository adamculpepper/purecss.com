<div style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:.5rem">
	<div style="background:var(--coral-dim);color:var(--coral);border:2px solid var(--coral);padding:.55rem 1.25rem;border-radius:7px;font-weight:600;font-size:.85rem;cursor:pointer;opacity:.4;pointer-events:none">🗑 Delete Account</div>
	<div style="display:flex;align-items:center;gap:.6rem;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:.5rem .9rem;animation:confirm-slide-in .2s ease">
		<span style="font-size:.8rem;color:var(--text-muted)">Are you sure?</span>
		<button style="padding:.3rem .7rem;background:var(--coral);color:#fff;border:none;border-radius:5px;font-size:.75rem;font-weight:600;cursor:pointer">Yes</button>
		<span style="font-size:.75rem;color:var(--text-muted);cursor:pointer">Cancel</span>
	</div>
</div>
