<div style="display:flex;gap:1rem;align-items:center;justify-content:center;padding:.5rem">
	<div style="position:relative;width:80px;height:80px">
		<svg style="transform:rotate(-90deg)" width="80" height="80" viewBox="0 0 80 80">
			<circle fill="none" stroke="var(--surface-2)" stroke-width="8" cx="40" cy="40" r="32"/>
			<circle fill="none" stroke="var(--accent)" stroke-width="8" stroke-linecap="round" cx="40" cy="40" r="32" stroke-dasharray="201" stroke-dashoffset="50" style="animation:donut-draw 1.4s ease .2s both"/>
		</svg>
		<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;transform:rotate(0deg)">
			<span style="font-size:.95rem;font-weight:700;color:var(--accent);font-family:monospace">75%</span>
		</div>
	</div>
	<div style="position:relative;width:70px;height:70px">
		<svg style="transform:rotate(-90deg)" width="70" height="70" viewBox="0 0 70 70">
			<circle fill="none" stroke="var(--surface-2)" stroke-width="7" cx="35" cy="35" r="28"/>
			<circle fill="none" stroke="var(--sky)" stroke-width="7" stroke-linecap="round" cx="35" cy="35" r="28" stroke-dasharray="176" stroke-dashoffset="70" style="animation:donut-draw 1.4s ease .4s both"/>
		</svg>
		<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
			<span style="font-size:.85rem;font-weight:700;color:var(--sky);font-family:monospace">60%</span>
		</div>
	</div>
	<div style="position:relative;width:60px;height:60px">
		<svg style="transform:rotate(-90deg)" width="60" height="60" viewBox="0 0 60 60">
			<circle fill="none" stroke="var(--surface-2)" stroke-width="6" cx="30" cy="30" r="24"/>
			<circle fill="none" stroke="var(--coral)" stroke-width="6" stroke-linecap="round" cx="30" cy="30" r="24" stroke-dasharray="151" stroke-dashoffset="18" style="animation:donut-draw 1.4s ease .6s both"/>
		</svg>
		<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
			<span style="font-size:.75rem;font-weight:700;color:var(--coral);font-family:monospace">88%</span>
		</div>
	</div>
</div>
