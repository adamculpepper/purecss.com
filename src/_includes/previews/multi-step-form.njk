<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;font-size:.8rem">
	<div style="display:flex;background:var(--surface-2);border-bottom:1px solid var(--border)">
		<span style="flex:1;padding:.4rem;text-align:center;color:var(--accent);border-bottom:2px solid var(--accent);font-size:.7rem;font-weight:600">1. Info</span>
		<span style="flex:1;padding:.4rem;text-align:center;color:var(--text-muted);font-size:.7rem">2. Details</span>
		<span style="flex:1;padding:.4rem;text-align:center;color:var(--text-muted);font-size:.7rem">3. Done</span>
	</div>
	<div style="padding:.75rem;display:flex;flex-direction:column;gap:.4rem">
		<input type="text" placeholder="Full name" style="width:100%;padding:.4rem .6rem;background:var(--surface-2);border:1px solid var(--border);border-radius:5px;color:var(--text);font-size:.75rem;font-family:inherit;outline:none">
		<input type="email" placeholder="Email address" style="width:100%;padding:.4rem .6rem;background:var(--surface-2);border:1px solid var(--border);border-radius:5px;color:var(--text);font-size:.75rem;font-family:inherit;outline:none">
		<div style="background:var(--accent);color:var(--bg);padding:.35rem .8rem;border-radius:5px;font-size:.75rem;font-weight:600;display:inline-block;align-self:flex-end;cursor:pointer">Next →</div>
	</div>
</div>
