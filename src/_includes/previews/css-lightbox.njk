<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.4rem">
	<div style="aspect-ratio:1;border-radius:5px;background:linear-gradient(135deg,var(--violet),var(--sky));cursor:zoom-in"></div>
	<div style="aspect-ratio:1;border-radius:5px;background:linear-gradient(135deg,var(--coral),var(--orange));cursor:zoom-in"></div>
	<div style="aspect-ratio:1;border-radius:5px;background:linear-gradient(135deg,var(--accent),var(--teal));cursor:zoom-in;border:2px solid var(--accent)"></div>
	<div style="aspect-ratio:1;border-radius:5px;background:linear-gradient(135deg,var(--rose),var(--violet));cursor:zoom-in"></div>
	<div style="aspect-ratio:1;border-radius:5px;background:linear-gradient(135deg,var(--orange),var(--yellow));cursor:zoom-in"></div>
	<div style="aspect-ratio:1;border-radius:5px;background:linear-gradient(135deg,var(--sky),var(--teal));cursor:zoom-in"></div>
</div>
