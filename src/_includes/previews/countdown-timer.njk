<div style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:.5rem">
	<div style="position:relative;width:90px;height:90px">
		<div style="position:absolute;inset:0;border-radius:50%;background:conic-gradient(var(--accent) calc(var(--countdown,7) * 36deg),var(--surface-2) 0);animation:countdown-ring 10s steps(10) infinite"></div>
		<div style="position:absolute;inset:6px;background:var(--bg);border-radius:50%;display:flex;align-items:center;justify-content:center">
			<div style="--countdown:7;counter-reset:num var(--countdown);font-size:2rem;font-weight:800;font-family:monospace;color:var(--accent);animation:countdown-num 10s steps(10) infinite;line-height:1">
				<span style="display:block;--countdown:7;counter-reset:n var(--countdown)">7</span>
			</div>
		</div>
	</div>
	<span style="font-size:.7rem;color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase">Seconds</span>
</div>
