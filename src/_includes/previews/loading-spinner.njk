<div style="display:flex;gap:1.5rem;align-items:center;justify-content:center;padding:.75rem">
	<div style="display:flex;flex-direction:column;align-items:center;gap:.4rem">
		<div style="width:32px;height:32px;border:3px solid var(--surface-2);border-top-color:var(--accent);border-radius:50%;animation:spin-ring .8s linear infinite"></div>
		<span style="font-size:.65rem;color:var(--text-muted)">Ring</span>
	</div>
	<div style="display:flex;flex-direction:column;align-items:center;gap:.4rem">
		<div style="display:flex;gap:4px;align-items:center">
			<div style="width:8px;height:8px;background:var(--accent);border-radius:50%;animation:spin-dots 1.2s ease-in-out infinite"></div>
			<div style="width:8px;height:8px;background:var(--accent);border-radius:50%;animation:spin-dots 1.2s ease-in-out .2s infinite"></div>
			<div style="width:8px;height:8px;background:var(--accent);border-radius:50%;animation:spin-dots 1.2s ease-in-out .4s infinite"></div>
		</div>
		<span style="font-size:.65rem;color:var(--text-muted)">Dots</span>
	</div>
	<div style="display:flex;flex-direction:column;align-items:center;gap:.4rem">
		<div style="display:flex;gap:3px;align-items:flex-end;height:28px">
			<div style="width:5px;background:var(--accent);border-radius:3px;animation:spin-bars 1s ease-in-out infinite"></div>
			<div style="width:5px;background:var(--accent);border-radius:3px;animation:spin-bars 1s ease-in-out .15s infinite"></div>
			<div style="width:5px;background:var(--accent);border-radius:3px;animation:spin-bars 1s ease-in-out .3s infinite"></div>
			<div style="width:5px;background:var(--accent);border-radius:3px;animation:spin-bars 1s ease-in-out .45s infinite"></div>
		</div>
		<span style="font-size:.65rem;color:var(--text-muted)">Bars</span>
	</div>
</div>
