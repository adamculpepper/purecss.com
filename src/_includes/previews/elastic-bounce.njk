<div style="display:flex;gap:2rem;align-items:flex-end;justify-content:center;height:110px;padding-bottom:.5rem;position:relative">
	<div style="display:flex;flex-direction:column;align-items:center;gap:.35rem;justify-content:flex-end;height:100%">
		<div style="width:32px;height:32px;border-radius:50%;background:radial-gradient(circle at 35% 35%,var(--accent),#6ddf00);animation:bounce-elastic 1.4s cubic-bezier(0.36,0.07,0.19,0.97) infinite"></div>
		<span style="font-size:.65rem;color:var(--text-muted)">Elastic</span>
	</div>
	<div style="display:flex;flex-direction:column;align-items:center;gap:.35rem;justify-content:flex-end;height:100%">
		<div style="width:28px;height:28px;border-radius:50%;background:radial-gradient(circle at 35% 35%,var(--sky),var(--violet));animation:bounce-spring 1.2s cubic-bezier(0.68,-0.55,0.265,1.55) infinite alternate"></div>
		<span style="font-size:.65rem;color:var(--text-muted)">Spring</span>
	</div>
	<div style="display:flex;flex-direction:column;align-items:center;gap:.35rem;justify-content:flex-end;height:100%">
		<div style="width:28px;height:28px;border-radius:50%;background:radial-gradient(circle at 35% 35%,var(--coral),var(--orange));animation:bounce-linear 1.4s linear infinite"></div>
		<span style="font-size:.65rem;color:var(--text-muted)">Linear</span>
	</div>
	<div style="position:absolute;bottom:1.6rem;left:5%;right:5%;height:1px;background:var(--border)"></div>
</div>
