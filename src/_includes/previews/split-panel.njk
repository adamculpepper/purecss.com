<div style="display:flex;border:1px solid var(--border);border-radius:8px;overflow:hidden;width:240px;height:120px">
	<div style="width:45%;border-right:1px solid var(--border);background:var(--surface);padding:.6rem .7rem;display:flex;flex-direction:column;gap:.3rem;position:relative;flex-shrink:0">
		<span style="font-family:var(--font-mono);font-size:.5rem;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted)">//files</span>
		<div style="background:var(--surface-2);border:1px solid var(--border);border-radius:4px;padding:.2rem .4rem;font-size:.55rem;color:var(--text)">index.njk</div>
		<div style="background:var(--surface-2);border:1px solid var(--border);border-radius:4px;padding:.2rem .4rem;font-size:.55rem;color:var(--text)">global.css</div>
		<div style="background:var(--surface-2);border:1px solid var(--border);border-radius:4px;padding:.2rem .4rem;font-size:.55rem;color:var(--text)">eleventy.config.js</div>
		<span style="position:absolute;bottom:.2rem;right:.2rem;font-size:.55rem;color:var(--text-muted);opacity:.5">⠿</span>
	</div>
	<div style="flex:1;background:var(--surface-2);padding:.6rem .7rem">
		<span style="font-family:var(--font-mono);font-size:.5rem;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted)">//preview</span>
	</div>
</div>
