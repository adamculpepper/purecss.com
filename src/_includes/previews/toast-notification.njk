<div style="display:flex;flex-direction:column;gap:.5rem;padding:.25rem">
	<div style="display:flex;align-items:center;gap:.6rem;background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--teal);border-radius:8px;padding:.6rem .8rem;font-size:.8rem;box-shadow:0 4px 16px rgba(0,0,0,.2)">
		<span style="color:var(--teal)">✓</span>
		<span style="flex:1">Changes saved successfully!</span>
		<span style="color:var(--text-muted);cursor:pointer;font-size:.9rem">✕</span>
	</div>
	<div style="display:flex;align-items:center;gap:.6rem;background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--sky);border-radius:8px;padding:.6rem .8rem;font-size:.8rem;opacity:.7">
		<span style="color:var(--sky)">ℹ</span>
		<span style="flex:1">Session expires in 5 minutes.</span>
		<span style="color:var(--text-muted);font-size:.9rem">✕</span>
	</div>
</div>
