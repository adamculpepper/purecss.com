<div style="display:flex;flex-direction:column;gap:.5rem;align-items:center;padding:.5rem">
	<div style="display:flex;align-items:center;border:2px solid var(--accent);border-radius:6px;overflow:hidden;width:140px">
		<button style="width:36px;background:var(--surface);border:none;border-right:1px solid var(--border);color:var(--text);font-size:1.1rem;padding:.5rem 0;cursor:pointer;line-height:1">−</button>
		<input type="number" value="7" style="flex:1;appearance:textfield;-moz-appearance:textfield;border:none;background:var(--surface-2);color:var(--text);font-family:inherit;font-size:.9rem;font-weight:600;text-align:center;padding:.45rem 0;outline:none">
		<button style="width:36px;background:var(--surface);border:none;border-left:1px solid var(--border);color:var(--text);font-size:1.1rem;padding:.5rem 0;cursor:pointer;line-height:1">+</button>
	</div>
	<input type="number" value="42" style="appearance:textfield;-moz-appearance:textfield;width:140px;padding:.5rem .75rem;background:var(--surface-2);border:2px solid var(--border);border-radius:6px;color:var(--text);font-family:monospace;font-size:1rem;font-weight:600;text-align:center;outline:none">
</div>
