<div style="display:flex;flex-direction:column;gap:.6rem;align-items:center;padding:.75rem">
	<button style="padding:.6rem 1.5rem;background:var(--accent);color:var(--bg);border:none;border-radius:7px;font-weight:600;font-size:.85rem;cursor:pointer;box-shadow:0 8px 24px rgba(184,255,87,.3);transform:translateY(-4px) scale(1.04);transition:transform .3s,box-shadow .3s">Primary ↑</button>
	<button style="padding:.6rem 1.5rem;background:var(--sky);color:#0a0a0b;border:none;border-radius:7px;font-weight:600;font-size:.85rem;cursor:pointer;box-shadow:0 4px 12px rgba(56,189,248,.2);transition:transform .3s,box-shadow .3s">Blue</button>
</div>
