				<th style="padding:.4rem .6rem;text-align:left;color:var(--text-muted);font-size:.65rem;text-transform:uppercase;border-bottom:1px solid var(--border)">Role</th>
				<th style="padding:.4rem .6rem;text-align:left;color:var(--text-muted);font-size:.65rem;text-transform:uppercase;border-bottom:1px solid var(--border)">Status</th>
			</tr>
		</thead>
		<tbody>
			<tr style="border-bottom:1px solid var(--border)">
				<td style="padding:.35rem .6rem;font-weight:500">Alice Chen</td>
				<td style="padding:.35rem .6rem;color:var(--text-muted)">Designer</td>
				<td style="padding:.35rem .6rem"><span style="background:rgba(87,217,163,.12);color:var(--teal);padding:.1rem .4rem;border-radius:99px;font-size:.65rem;font-weight:600">Active</span></td>
			</tr>
			<tr style="border-bottom:1px solid var(--border)">
				<td style="padding:.35rem .6rem;font-weight:500">Bob Torres</td>
				<td style="padding:.35rem .6rem;color:var(--text-muted)">Engineer</td>
				<td style="padding:.35rem .6rem"><span style="background:rgba(255,212,68,.12);color:var(--yellow);padding:.1rem .4rem;border-radius:99px;font-size:.65rem;font-weight:600">Pending</span></td>
			</tr>
			<tr style="border-bottom:1px solid var(--border)">
				<td style="padding:.35rem .6rem;font-weight:500">Carol Kim</td>
				<td style="padding:.35rem .6rem;color:var(--text-muted)">Manager</td>
				<td style="padding:.35rem .6rem"><span style="background:rgba(87,217,163,.12);color:var(--teal);padding:.1rem .4rem;border-radius:99px;font-size:.65rem;font-weight:600">Active</span></td>
			</tr>
			<tr>
				<td style="padding:.35rem .6rem;font-weight:500">David Park</td>
				<td style="padding:.35rem .6rem;color:var(--text-muted)">Analyst</td>
				<td style="padding:.35rem .6rem"><span style="background:var(--surface-2);color:var(--text-muted);padding:.1rem .4rem;border-radius:99px;font-size:.65rem;font-weight:600">Inactive</span></td>
			</tr>
		</tbody>
