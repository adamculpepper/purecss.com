<div class="counter-preview-wrap">
	<div class="counter-controls">
		<button class="counter-speed-btn" onclick="setCounterSpeed(this,'4s')">Slow</button>
		<button class="counter-speed-btn active" onclick="setCounterSpeed(this,'2s')">Med</button>
		<button class="counter-speed-btn" onclick="setCounterSpeed(this,'0.6s')">Fast</button>
		<button class="counter-restart-mini" title="Restart" onclick="restartCounters(this)">↺</button>
	</div>
	<div class="counter-grid">
		<div class="counter-item">
			<div class="counter-value" style="--target: 42"></div>
			<div class="counter-label">Examples</div>
		</div>
		<div class="counter-item">
			<div class="counter-value" style="--target: 100" data-suffix="%"></div>
			<div class="counter-label">Pure CSS</div>
		</div>
	</div>
</div>
<script>
function setCounterSpeed(btn, dur) {
	var demo = btn.closest('.demo-number-counter');
	btn.parentElement.querySelectorAll('.counter-speed-btn').forEach(function(b){ b.classList.remove('active'); });
	btn.classList.add('active');
	demo.style.setProperty('--count-dur', dur);
	restartCounters(btn);
}
function restartCounters(el) {
	el.closest('.demo-number-counter').querySelectorAll('.counter-value').forEach(function(v){
		v.style.animation = 'none';
		v.offsetHeight;
		v.style.animation = '';
	});
}
</script>
