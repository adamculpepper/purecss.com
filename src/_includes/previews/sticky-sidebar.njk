<div style="display:grid;grid-template-columns:90px 1fr;gap:.5rem;height:110px;overflow:hidden">
	<div style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:.4rem;font-size:.7rem">
		<div style="color:var(--text-muted);font-size:.6rem;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.3rem;font-weight:600">Contents</div>
		<div style="background:var(--accent-dim);color:var(--accent);padding:.2rem .4rem;border-radius:4px;font-weight:600;margin-bottom:.15rem">Intro</div>
		<div style="color:var(--text-muted);padding:.2rem .4rem;margin-bottom:.15rem">Install</div>
		<div style="color:var(--text-muted);padding:.2rem .4rem;margin-bottom:.15rem">Usage</div>
		<div style="color:var(--text-muted);padding:.2rem .4rem">API</div>
	</div>
	<div style="display:flex;flex-direction:column;gap:.4rem;overflow:hidden">
		<div style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:.5rem">
			<div style="font-size:.7rem;font-weight:600;color:var(--accent);margin-bottom:.2rem">Intro</div>
			<div style="font-size:.65rem;color:var(--text-muted)">Sidebar uses position: sticky to stay visible while content scrolls.</div>
		</div>
		<div style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:.5rem">
			<div style="font-size:.7rem;font-weight:600;color:var(--accent);margin-bottom:.2rem">Install</div>
			<div style="font-size:.65rem;color:var(--text-muted)">No dependencies. Copy CSS into your project.</div>
		</div>
	</div>
</div>
