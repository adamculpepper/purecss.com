<div style="position:relative;height:110px;overflow:hidden;border-radius:8px;background:var(--surface);display:flex;align-items:center;justify-content:center">
	<div style="position:absolute;top:-10px;left:5%;width:8px;height:12px;background:var(--coral);border-radius:2px;animation:confetti-fall 2.8s ease-in infinite"></div>
	<div style="position:absolute;top:-10px;left:15%;width:10px;height:10px;background:var(--accent);border-radius:50%;animation:confetti-fall 3.1s ease-in .3s infinite"></div>
	<div style="position:absolute;top:-10px;left:25%;width:6px;height:14px;background:var(--sky);animation:confetti-fall 2.6s ease-in .6s infinite"></div>
	<div style="position:absolute;top:-10px;left:35%;width:10px;height:6px;background:var(--yellow);animation:confetti-fall 2.9s ease-in .8s infinite"></div>
	<div style="position:absolute;top:-10px;left:45%;width:8px;height:8px;background:var(--rose);border-radius:50%;animation:confetti-fall 3.2s ease-in .4s infinite"></div>
	<div style="position:absolute;top:-10px;left:55%;width:12px;height:6px;background:var(--teal);animation:confetti-fall 2.7s ease-in 1s infinite"></div>
	<div style="position:absolute;top:-10px;left:65%;width:6px;height:10px;background:var(--violet);animation:confetti-fall 3.0s ease-in .2s infinite"></div>
	<div style="position:absolute;top:-10px;left:75%;width:8px;height:12px;background:var(--orange);animation:confetti-fall 2.8s ease-in .7s infinite"></div>
	<div style="position:absolute;top:-10px;left:85%;width:10px;height:8px;background:var(--accent);animation:confetti-fall 3.1s ease-in .5s infinite"></div>
	<div style="position:absolute;top:-10px;left:93%;width:6px;height:6px;background:var(--coral);border-radius:50%;animation:confetti-fall 2.6s ease-in .15s infinite"></div>
	<p style="position:relative;z-index:1;font-size:1.1rem;font-weight:700;margin:0">🎉 Congrats!</p>
</div>
