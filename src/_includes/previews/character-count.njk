<div class="cc-field" style="padding:.5rem">
	<input type="text" minlength="2" maxlength="20" placeholder="Type here..." style="width:100%;padding:.5rem .75rem;background:var(--surface-2);border:2px solid var(--accent);border-radius:6px;color:var(--text);font-family:inherit;font-size:.8rem;outline:none">
	<div class="cc-meta" style="display:flex;justify-content:space-between;font-size:.7rem;margin-top:.25rem;color:var(--teal)">
		<span>✓ Looks good</span><span>Max 20</span>
	</div>
</div>
