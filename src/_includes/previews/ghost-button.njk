<div style="display:flex;flex-direction:column;gap:.6rem;align-items:center;padding:.75rem">
	<div style="position:relative;padding:.6rem 1.5rem;border:2px solid var(--accent);border-radius:7px;font-weight:600;font-size:.85rem;overflow:hidden;color:var(--bg)">
		<div style="position:absolute;inset:0;background:var(--accent)"></div>
		<span style="position:relative;z-index:1">Filled →</span>
	</div>
	<div style="position:relative;padding:.6rem 1.5rem;border:2px solid var(--sky);border-radius:7px;font-weight:600;font-size:.85rem;overflow:hidden;color:var(--sky)">
		<div style="position:absolute;inset:0;background:var(--sky);transform:translateX(-60%)"></div>
		<span style="position:relative;z-index:1">Sweeping</span>
	</div>
</div>
